{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,

    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": false,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "paths": {
      "@/*": ["./src/*"]
    },
  },
  "include": ["src/ikoncomponents", "src/types", "src/utils"],
  "exclude": ["node_modules","src/main.tsx", "src/App.tsx"]
}